export LC_TIME=en_US.UTF-8

cdgsn() {
    source "$BASE_TOOL_PATH/cd_dir_tool/cd_dir_gsn.sh" "$@"
}
cdgsp() {
    source "$BASE_TOOL_PATH/cd_dir_tool/cd_dir_gsp.sh" "$@"
}

source /home/ericlee/quanta_openbmc_toolbox/ssh_utils.sh

export BASE_TOOL_PATH=$HOME/quanta_openbmc_toolbox
export PATH="$HOME/quanta_openbmc_toolbox:$PATH"
export PATH="$HOME/ericlee/Downloads/Antigravity/Antigravity-x64:$PATH"

alias flashrom_gsn='flashrom -p ch347_spi:spispeed=60M -w ~/repo_GSN/build-gsn/tmp/deploy/images/gsn/image-bmc'
alias crashdump_save='/home/ericlee/Downloads/from_Eric/20260606_crashdump_modify/scp_crashdump.sh'

alias bb="bitbake -c cleanall obmc-phosphor-image -f && bitbake obmc-phosphor-image"
alias kernel_bb="bitbake -c cleansstate virtual/kernel && bitbake -c cleanall obmc-phosphor-image -f && bitbake obmc-phosphor-image"
alias crashdump_bb="bitbake crashdump -c compile -f && bitbake crashdump -c install -f && bitbake obmc-phosphor-image"
